# Copy this file to config.env (same folder as ingest_daily_snapshot.py).
# Do not put secrets in config.example.env — git may track it.

# Required for US exchange batch quotes via OpenBB FMP provider.
FMP_API_KEY=REPLACE_ME

# Primary database (pick one):
# DATABASE_URL=sqlite:///e:/finance/OpenBB/leon/data/market.db
#
# Postgres URL: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
# USER/PASSWORD/DBNAME must exist in PostgreSQL (example below is only a template).
# If PASSWORD contains @ : # etc., URL-encode it (e.g. @ -> %40).
DATABASE_URL=postgresql+psycopg://leon:CHANGE_ME_PASSWORD@localhost:5432/leon

# Optional: also write the same data to SQLite (Postgres + SQLite dual landing).
DATABASE_MIRROR_URL=sqlite:///e:/finance/OpenBB/leon/data/market.db

# Comma-separated FMP exchange codes (lowercase). US-listed common stock venues:
LEON_US_EXCHANGES=nyse,nasdaq,amex

# --- PostgreSQL only: daily_quotes is RANGE(trade_date) + yearly child partitions (init_db) ---
# SQLite mirror stays a single non-partitioned table.
# LEON_PARTITION_YEAR_FROM=2018
# LEON_PARTITION_YEAR_TO=2030

# Postgres pool (used by concurrent backfill)
# LEON_DB_POOL_SIZE=24
# LEON_DB_MAX_OVERFLOW=48

# --- ingest_eod_backfill.py (5y history; run after symbol_registry exists) ---
# LEON_EOD_BACKFILL_YEARS=5
# LEON_EOD_PROVIDER=fmp
# LEON_BACKFILL_WORKERS=16
# LEON_BACKFILL_SLEEP_SEC=0
# LEON_BACKFILL_SERIAL_FETCH=0
# LEON_BACKFILL_LIMIT=0
# LEON_BACKFILL_EXCHANGES=nasdaq,nyse,amex
# LEON_BACKFILL_RESUME=1
# LEON_BACKFILL_PROGRESS_EVERY=1000
# LEON_BACKFILL_PROGRESS_FILE=e:/finance/OpenBB/leon/data/backfill_progress.json
# LEON_BACKFILL_CLEAR_PROGRESS_ON_COMPLETE=1

# --- macro full + incremental ---
# First run full 5y:
# python leon/data/macro_series_seed.py
# python leon/data/ingest_macro_full.py
# Then schedule incremental:
# python leon/data/ingest_macro_incremental.py
#
# Optional FRED key (many series can be queried without it but key is recommended):
# FRED_API_KEY=REPLACE_ME
# LEON_MACRO_FULL_YEARS=5
# LEON_MACRO_BOOTSTRAP_YEARS=5
# LEON_MACRO_INCREMENTAL_BUFFER_DAYS=14
# LEON_MACRO_MAX_PRIORITY=3
# LEON_MACRO_WORKERS=8

# --- panic/liquidity composite score ---
# Run after macro full/incremental:
# python leon/data/build_panic_liquidity_score.py

# --- alt series: Nothing Ever Happens Index (API JSON source, no CSV file) ---
# Add row in macro_series_catalog is already seeded as provider=alt, series_id=NOTHING_EVER_HAPPENS_INDEX.
# Supported JSON:
# 1) Root list: [{date: "...", value: ...}, ...]
# 2) Object root with list in `data`: {"data":[{...}, ...]}
# 3) NEH endpoint shape: {"global_index": 37, "timestamp": "...", ...}
# LEON_PIZZA_SOURCE_URL=https://www.pizzint.watch/api/neh-index
# Optional: dedicated history endpoint for NEH backfill (preferred for macro_full).
# LEON_PIZZA_HISTORY_URL=https://www.pizzint.watch/api/neh-index/history
# LEON_PIZZA_JSON_ROOT_KEY=data
# LEON_PIZZA_JSON_DATE_FIELD=date
# LEON_PIZZA_JSON_VALUE_FIELD=value
# LEON_PIZZA_JSON_SERIES_FIELD=series_id
# LEON_PIZZA_SOURCE_SCALE=1.0
# LEON_PIZZA_TEST_SERIES_ID=NOTHING_EVER_HAPPENS_INDEX
# Fallback (if URL is HTML / no JSON API): parse DOUGHCON from page.
# LEON_PIZZA_FALLBACK_URL=https://www.pizzint.watch
# LEON_PIZZA_FALLBACK_INVERT=1
# Precheck before full/incremental:
# python leon/data/check_pizza_source.py
